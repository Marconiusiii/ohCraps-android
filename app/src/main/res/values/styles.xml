<?xml version="1.0" encoding="utf-8"?>
<resources>

	<style name="TextAppearance.OhCraps.ScreenTitle" parent="TextAppearance.Material3.HeadlineLarge">
		<item name="fontFamily">serif</item>
		<item name="android:textColor">@color/accent_gold</item>
		<item name="android:textStyle">bold</item>
	</style>

	<style name="TextAppearance.OhCraps.SectionHeading" parent="TextAppearance.Material3.TitleMedium">
		<item name="android:textColor">@color/accent_gold</item>
		<item name="android:textStyle">bold</item>
	</style>

	<style name="TextAppearance.OhCraps.Body" parent="TextAppearance.Material3.BodyLarge">
		<item name="android:textColor">@color/text_primary</item>
	</style>

	<style name="TextAppearance.OhCraps.ListItem" parent="TextAppearance.Material3.BodyMedium">
		<item name="android:textColor">@color/text_primary</item>
	</style>

	<style name="TextAppearance.OhCraps.BottomNav" parent="TextAppearance.Material3.LabelLarge">
		<item name="android:textColor">@color/text_primary</item>
		<item name="android:textSize">@dimen/bottomNavTextAppearanceSize</item>
		<item name="android:textStyle">bold</item>
	</style>

	<style name="TextAppearance.OhCraps.DetailActionText" parent="TextAppearance.Material3.BodyLarge">
		<item name="android:textColor">@color/text_primary</item>
		<item name="android:textStyle">bold</item>
	</style>

	<style name="Widget.OhCraps.DetailActionButton" parent="Widget.Material3.Button">
		<item name="android:background">@drawable/bg_detail_share_action</item>
		<item name="android:textColor">@color/text_primary</item>
		<item name="android:textAllCaps">false</item>
		<item name="android:paddingStart">@dimen/detailActionPaddingHorizontal</item>
		<item name="android:paddingTop">@dimen/detailActionPaddingVertical</item>
		<item name="android:paddingEnd">@dimen/detailActionPaddingHorizontal</item>
		<item name="android:paddingBottom">@dimen/detailActionPaddingVertical</item>
		<item name="cornerRadius">14dp</item>
		<item name="strokeWidth">0dp</item>
		<item name="backgroundTint">@android:color/transparent</item>
		<item name="rippleColor">@android:color/transparent</item>
		<item name="android:insetTop">0dp</item>
		<item name="android:insetBottom">0dp</item>
	</style>

	<style name="Widget.OhCraps.ShareDetailButton" parent="Widget.Material3.Button">
		<item name="android:background">@drawable/bg_detail_share_primary</item>
		<item name="android:textColor">@color/detailShareText</item>
		<item name="android:textAllCaps">false</item>
		<item name="android:paddingStart">@dimen/detailActionPaddingHorizontal</item>
		<item name="android:paddingTop">@dimen/detailActionPaddingVertical</item>
		<item name="android:paddingEnd">@dimen/detailActionPaddingHorizontal</item>
		<item name="android:paddingBottom">@dimen/detailActionPaddingVertical</item>
		<item name="cornerRadius">14dp</item>
		<item name="strokeWidth">0dp</item>
		<item name="backgroundTint">@android:color/transparent</item>
		<item name="rippleColor">@android:color/transparent</item>
		<item name="android:insetTop">0dp</item>
		<item name="android:insetBottom">0dp</item>
	</style>

	<style name="Widget.OhCraps.FeltActionButton" parent="Widget.Material3.Button">
		<item name="android:background">@drawable/bg_detail_share_action</item>
		<item name="android:textColor">@color/text_primary</item>
		<item name="android:textAllCaps">false</item>
		<item name="android:minHeight">@dimen/detailActionMinHeight</item>
		<item name="android:paddingStart">@dimen/detailActionPaddingHorizontal</item>
		<item name="android:paddingTop">@dimen/detailActionPaddingVertical</item>
		<item name="android:paddingEnd">@dimen/detailActionPaddingHorizontal</item>
		<item name="android:paddingBottom">@dimen/detailActionPaddingVertical</item>
		<item name="cornerRadius">14dp</item>
		<item name="strokeWidth">0dp</item>
		<item name="backgroundTint">@android:color/transparent</item>
		<item name="rippleColor">@android:color/transparent</item>
		<item name="android:insetTop">0dp</item>
		<item name="android:insetBottom">0dp</item>
	</style>

	<style name="Widget.OhCraps.SearchField" parent="Widget.Material3.TextInputLayout.FilledBox">
		<item name="boxBackgroundMode">filled</item>
		<item name="boxBackgroundColor">@color/searchFieldFill</item>
		<item name="boxStrokeColor">@color/searchFieldStroke</item>
		<item name="hintTextColor">@color/text_secondary</item>
		<item name="android:textColorHint">@color/text_secondary</item>
		<item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.OhCraps.SearchField</item>
		<item name="endIconTint">@color/accent_gold</item>
	</style>

	<style name="Widget.OhCraps.FormField" parent="Widget.Material3.TextInputLayout.FilledBox">
		<item name="boxBackgroundMode">filled</item>
		<item name="boxBackgroundColor">@color/formFieldFill</item>
		<item name="boxStrokeColor">@color/formFieldStroke</item>
		<item name="hintTextColor">@color/text_secondary</item>
		<item name="android:textColorHint">@color/text_secondary</item>
		<item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.OhCraps.SearchField</item>
	</style>

	<style name="Widget.OhCraps.ModeButton" parent="Widget.Material3.Button">
		<item name="android:background">@drawable/bg_mode_button</item>
		<item name="android:textColor">@color/text_primary</item>
		<item name="android:textAllCaps">false</item>
		<item name="android:minHeight">@dimen/detailActionMinHeight</item>
		<item name="android:paddingStart">@dimen/detailActionPaddingHorizontal</item>
		<item name="android:paddingTop">@dimen/detailActionPaddingVertical</item>
		<item name="android:paddingEnd">@dimen/detailActionPaddingHorizontal</item>
		<item name="android:paddingBottom">@dimen/detailActionPaddingVertical</item>
		<item name="cornerRadius">14dp</item>
		<item name="strokeWidth">0dp</item>
		<item name="backgroundTint">@android:color/transparent</item>
		<item name="rippleColor">@android:color/transparent</item>
		<item name="android:insetTop">0dp</item>
		<item name="android:insetBottom">0dp</item>
	</style>

	<style name="ShapeAppearanceOverlay.OhCraps.SearchField" parent="">
		<item name="cornerFamily">rounded</item>
		<item name="cornerSize">14dp</item>
	</style>

</resources>
