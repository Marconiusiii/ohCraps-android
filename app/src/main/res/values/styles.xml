<?xml version="1.0" encoding="utf-8"?>
<resources>

	<style name="TextAppearance.OhCraps.ScreenTitle" parent="TextAppearance.Material3.HeadlineLarge">
		<item name="android:textColor">@color/accent_gold</item>
		<item name="android:textStyle">bold</item>
	</style>

	<style name="TextAppearance.OhCraps.SectionHeading" parent="TextAppearance.Material3.TitleMedium">
		<item name="android:textColor">@color/accent_gold</item>
		<item name="android:textStyle">bold</item>
	</style>

	<style name="TextAppearance.OhCraps.Body" parent="TextAppearance.Material3.BodyLarge">
		<item name="android:textColor">@color/text_primary</item>
	</style>

	<style name="TextAppearance.OhCraps.ListItem" parent="TextAppearance.Material3.BodyMedium">
		<item name="android:textColor">@color/text_primary</item>
	</style>

	<style name="Widget.OhCraps.BottomRailButton" parent="Widget.AppCompat.Button.Borderless">
		<item name="android:background">@drawable/bg_bottom_nav_button</item>
		<item name="android:textColor">@color/selector_bottom_nav_text</item>
		<item name="android:textAllCaps">false</item>
		<item name="android:textSize">@dimen/bottomNavButtonTextSize</item>
		<item name="android:minHeight">@dimen/bottomNavButtonMinHeight</item>
		<item name="android:gravity">center</item>
		<item name="android:maxLines">2</item>
		<item name="android:paddingStart">8dp</item>
		<item name="android:paddingTop">8dp</item>
		<item name="android:paddingEnd">8dp</item>
		<item name="android:paddingBottom">8dp</item>
	</style>

</resources>
