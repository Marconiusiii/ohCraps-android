<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical"
	android:background="@drawable/bg_felt"
	android:padding="@dimen/screenPadding">

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:orientation="horizontal"
		android:layout_marginBottom="@dimen/controlSpacing">

		<com.google.android.material.button.MaterialButton
			android:id="@+id/backButton"
			style="@style/Widget.Material3.Button.TextButton"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="@string/back_button"
			android:contentDescription="@string/back_button" />
	</LinearLayout>

	<TextView
		android:id="@+id/screenTitle"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:textAppearance="@style/TextAppearance.OhCraps.ScreenTitle"
		android:accessibilityHeading="true"
		android:layout_marginBottom="@dimen/controlSpacing" />

	<LinearLayout
		android:id="@+id/actionRow"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:orientation="horizontal"
		android:gravity="center_vertical"
		android:layout_marginBottom="@dimen/controlSpacing"
		android:visibility="gone">

		<LinearLayout
			android:id="@+id/favoriteContainer"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:layout_weight="1"
			android:minHeight="@dimen/detailActionMinHeight"
			android:paddingStart="@dimen/detailActionPaddingHorizontal"
			android:paddingTop="@dimen/detailActionPaddingVertical"
			android:paddingEnd="@dimen/detailActionPaddingHorizontal"
			android:paddingBottom="@dimen/detailActionPaddingVertical"
			android:background="@drawable/bg_detail_favorite_action"
			android:orientation="horizontal"
			android:gravity="center_vertical"
			android:clickable="true"
			android:focusable="true"
			android:importantForAccessibility="yes"
			android:visibility="gone">

			<ImageView
				android:id="@+id/favoriteIcon"
				android:layout_width="20dp"
				android:layout_height="20dp"
				android:layout_marginEnd="8dp"
				android:importantForAccessibility="no"
				android:contentDescription="@null"
				android:src="@drawable/selector_favorite_star" />

			<TextView
				android:id="@+id/favoriteLabel"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:importantForAccessibility="no"
				android:text="@string/favorite_strategy_toggle"
				android:textAppearance="@style/TextAppearance.OhCraps.DetailActionText" />
		</LinearLayout>

		<com.google.android.material.button.MaterialButton
			android:id="@+id/shareButton"
			style="@style/Widget.OhCraps.DetailActionButton"
			android:layout_width="wrap_content"
			android:layout_height="@dimen/detailActionMinHeight"
			android:layout_marginStart="@dimen/controlSpacing"
			android:text="@string/share_strategy_button"
			android:contentDescription="@string/share_strategy_button"
			android:visibility="gone" />
	</LinearLayout>

	<com.google.android.material.button.MaterialButton
		android:id="@+id/actionsButton"
		style="@style/Widget.Material3.Button.OutlinedButton"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:text="@string/user_strategy_actions_button"
		android:contentDescription="@string/user_strategy_actions_button"
		android:visibility="gone"
		android:layout_marginBottom="@dimen/controlSpacing" />

	<TextView
		android:id="@+id/submissionStatusText"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:textAppearance="@style/TextAppearance.OhCraps.Body"
		android:layout_marginBottom="@dimen/sectionSpacing"
		android:visibility="gone" />

	<ScrollView
		android:layout_width="match_parent"
		android:layout_height="0dp"
		android:layout_weight="1">

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical">

			<TextView
				android:id="@+id/buyInValue"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:textAppearance="@style/TextAppearance.OhCraps.Body"
				android:layout_marginBottom="@dimen/controlSpacing" />

			<TextView
				android:id="@+id/tableMinValue"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:textAppearance="@style/TextAppearance.OhCraps.Body"
				android:layout_marginBottom="@dimen/sectionSpacing" />

			<LinearLayout
				android:id="@+id/notesSection"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="vertical"
				android:layout_marginBottom="@dimen/sectionSpacing">

				<TextView
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:text="@string/notes_heading"
					android:textAppearance="@style/TextAppearance.OhCraps.SectionHeading"
					android:accessibilityHeading="true" />

				<TextView
					android:id="@+id/notesText"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:textAppearance="@style/TextAppearance.OhCraps.Body" />
			</LinearLayout>

			<LinearLayout
				android:id="@+id/creditSection"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="vertical"
				android:layout_marginBottom="@dimen/sectionSpacing">

				<TextView
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:text="@string/credit_heading"
					android:textAppearance="@style/TextAppearance.OhCraps.SectionHeading"
					android:accessibilityHeading="true" />

				<TextView
					android:id="@+id/creditText"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:textAppearance="@style/TextAppearance.OhCraps.Body" />
			</LinearLayout>

			<TextView
				android:id="@+id/stepsHeading"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="@string/steps_heading"
				android:textAppearance="@style/TextAppearance.OhCraps.SectionHeading"
				android:accessibilityHeading="true"
				android:layout_marginBottom="@dimen/controlSpacing" />

			<LinearLayout
				android:id="@+id/stepsContainer"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="vertical" />

		</LinearLayout>
	</ScrollView>

</LinearLayout>
