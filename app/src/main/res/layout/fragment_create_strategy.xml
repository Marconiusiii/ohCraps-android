<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical"
	android:background="@drawable/bg_felt"
	android:padding="@dimen/screenPadding">

	<TextView
		android:id="@+id/screenTitle"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:gravity="center_horizontal"
		android:textAlignment="center"
		android:text="@string/title_create_strategy"
		android:textAppearance="@style/TextAppearance.OhCraps.ScreenTitle"
		android:accessibilityHeading="true"
		android:layout_marginBottom="@dimen/controlSpacing" />

	<LinearLayout
		android:id="@+id/modeButtonsRow"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:orientation="horizontal"
		android:layout_marginBottom="@dimen/controlSpacing">

		<com.google.android.material.button.MaterialButton
			android:id="@+id/createModeButton"
			style="@style/Widget.OhCraps.ModeButton"
			android:layout_width="0dp"
			android:layout_height="@dimen/detailActionMinHeight"
			android:layout_weight="1"
			android:text="@string/create_mode_label"
			android:layout_marginEnd="@dimen/controlSpacing" />

		<com.google.android.material.button.MaterialButton
			android:id="@+id/myStrategiesModeButton"
			style="@style/Widget.OhCraps.ModeButton"
			android:layout_width="0dp"
			android:layout_height="@dimen/detailActionMinHeight"
			android:layout_weight="1"
			android:text="@string/my_strategies_mode_label" />
	</LinearLayout>

	<FrameLayout
		android:layout_width="match_parent"
		android:layout_height="0dp"
		android:layout_weight="1">

		<ScrollView
			android:id="@+id/createFormContainer"
			android:layout_width="match_parent"
			android:layout_height="match_parent">

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="vertical"
				android:paddingBottom="@dimen/screenPadding">

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical"
					android:background="@drawable/bg_content_zone"
					android:padding="@dimen/contentZonePadding"
					android:layout_marginBottom="@dimen/zoneSpacing">

					<TextView
						android:id="@+id/requiredHint"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:text="@string/create_required_hint"
						android:textAppearance="@style/TextAppearance.OhCraps.ListItem"
						android:layout_marginBottom="@dimen/controlSpacing" />

					<TextView
						android:id="@+id/nameLabel"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:text="@string/create_name_label"
						android:labelFor="@id/nameInput"
						android:importantForAccessibility="no"
						android:textAppearance="@style/TextAppearance.OhCraps.SectionHeading"
						android:layout_marginBottom="4dp" />

					<com.google.android.material.textfield.TextInputLayout
						android:id="@+id/nameInputLayout"
						style="@style/Widget.OhCraps.FormField"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:hint="@string/create_name_label"
						android:importantForAccessibility="no"
						android:layout_marginBottom="@dimen/controlSpacing">

						<com.google.android.material.textfield.TextInputEditText
							android:id="@+id/nameInput"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:contentDescription="@string/create_name_label"
							android:inputType="textCapSentences"
							android:imeOptions="actionNext" />
					</com.google.android.material.textfield.TextInputLayout>

					<TextView
						android:id="@+id/buyInLabel"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:text="@string/create_buy_in_label"
						android:labelFor="@id/buyInInput"
						android:importantForAccessibility="no"
						android:textAppearance="@style/TextAppearance.OhCraps.SectionHeading"
						android:layout_marginBottom="4dp" />

					<com.google.android.material.textfield.TextInputLayout
						android:id="@+id/buyInInputLayout"
						style="@style/Widget.OhCraps.FormField"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:hint="@string/create_buy_in_label"
						android:importantForAccessibility="no"
						android:layout_marginBottom="@dimen/controlSpacing">

						<com.google.android.material.textfield.TextInputEditText
							android:id="@+id/buyInInput"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:contentDescription="@string/create_buy_in_label"
							android:inputType="text"
							android:imeOptions="actionNext" />
					</com.google.android.material.textfield.TextInputLayout>

					<TextView
						android:id="@+id/tableMinimumLabel"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:text="@string/create_table_minimum_label"
						android:labelFor="@id/tableMinimumInput"
						android:importantForAccessibility="no"
						android:textAppearance="@style/TextAppearance.OhCraps.SectionHeading"
						android:layout_marginBottom="4dp" />

					<com.google.android.material.textfield.TextInputLayout
						android:id="@+id/tableMinimumInputLayout"
						style="@style/Widget.OhCraps.FormField"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:hint="@string/create_table_minimum_label"
						android:importantForAccessibility="no">

						<com.google.android.material.textfield.TextInputEditText
							android:id="@+id/tableMinimumInput"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:contentDescription="@string/create_table_minimum_label"
							android:inputType="text"
							android:imeOptions="actionNext" />
					</com.google.android.material.textfield.TextInputLayout>
				</LinearLayout>

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical"
					android:background="@drawable/bg_content_zone"
					android:padding="@dimen/contentZonePadding"
					android:layout_marginBottom="@dimen/zoneSpacing">

					<TextView
						android:id="@+id/stepsLabel"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:text="@string/create_steps_label"
						android:labelFor="@id/stepsInput"
						android:importantForAccessibility="no"
						android:textAppearance="@style/TextAppearance.OhCraps.SectionHeading"
						android:layout_marginBottom="4dp" />

					<com.google.android.material.textfield.TextInputLayout
						android:id="@+id/stepsInputLayout"
						style="@style/Widget.OhCraps.FormField"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:hint="@string/create_steps_label"
						android:importantForAccessibility="no"
						android:layout_marginBottom="@dimen/controlSpacing">

						<com.google.android.material.textfield.TextInputEditText
							android:id="@+id/stepsInput"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:contentDescription="@string/create_steps_label"
							android:minLines="4"
							android:gravity="top|start"
							android:inputType="textMultiLine|textCapSentences"
							android:imeOptions="actionNext" />
					</com.google.android.material.textfield.TextInputLayout>

					<TextView
						android:id="@+id/notesLabel"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:text="@string/create_notes_label"
						android:labelFor="@id/notesInput"
						android:importantForAccessibility="no"
						android:textAppearance="@style/TextAppearance.OhCraps.SectionHeading"
						android:layout_marginBottom="4dp" />

					<com.google.android.material.textfield.TextInputLayout
						android:id="@+id/notesInputLayout"
						style="@style/Widget.OhCraps.FormField"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:hint="@string/create_notes_label"
						android:importantForAccessibility="no"
						android:layout_marginBottom="@dimen/controlSpacing">

						<com.google.android.material.textfield.TextInputEditText
							android:id="@+id/notesInput"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:contentDescription="@string/create_notes_label"
							android:minLines="3"
							android:gravity="top|start"
							android:inputType="textMultiLine|textCapSentences"
							android:imeOptions="actionNext" />
					</com.google.android.material.textfield.TextInputLayout>

					<TextView
						android:id="@+id/creditLabel"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:text="@string/create_credit_label"
						android:labelFor="@id/creditInput"
						android:importantForAccessibility="no"
						android:textAppearance="@style/TextAppearance.OhCraps.SectionHeading"
						android:layout_marginBottom="4dp" />

					<com.google.android.material.textfield.TextInputLayout
						android:id="@+id/creditInputLayout"
						style="@style/Widget.OhCraps.FormField"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:hint="@string/create_credit_label"
						android:importantForAccessibility="no">

						<com.google.android.material.textfield.TextInputEditText
							android:id="@+id/creditInput"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:contentDescription="@string/create_credit_label"
							android:inputType="textCapSentences"
							android:imeOptions="actionDone" />
					</com.google.android.material.textfield.TextInputLayout>
				</LinearLayout>

				<LinearLayout
					android:id="@+id/createButtonsRow"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="horizontal"
					android:background="@drawable/bg_content_zone"
					android:padding="@dimen/contentZonePadding">

					<com.google.android.material.button.MaterialButton
						android:id="@+id/primaryActionButton"
						style="@style/Widget.OhCraps.FeltActionButton"
						android:layout_width="0dp"
						android:layout_height="@dimen/detailActionMinHeight"
						android:layout_weight="1"
						android:text="@string/create_save_strategy" />

					<com.google.android.material.button.MaterialButton
						android:id="@+id/secondaryActionButton"
						style="@style/Widget.OhCraps.FeltActionButton"
						android:layout_width="0dp"
						android:layout_height="@dimen/detailActionMinHeight"
						android:layout_weight="1"
						android:layout_marginStart="@dimen/controlSpacing"
						android:text="@string/create_reset_form" />
				</LinearLayout>
			</LinearLayout>
		</ScrollView>

		<LinearLayout
			android:id="@+id/myStrategiesContainer"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:orientation="vertical"
			android:visibility="gone"
			android:background="@drawable/bg_content_zone"
			android:padding="@dimen/contentZonePadding">

			<TextView
				android:id="@+id/emptyMyStrategiesText"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="@string/my_strategies_empty"
				android:textAppearance="@style/TextAppearance.OhCraps.Body"
				android:visibility="gone"
				android:layout_marginBottom="@dimen/controlSpacing" />

			<androidx.recyclerview.widget.RecyclerView
				android:id="@+id/myStrategiesRecyclerView"
				android:layout_width="match_parent"
				android:layout_height="0dp"
				android:layout_weight="1"
				android:clipToPadding="false"
				android:paddingBottom="@dimen/screenPadding" />
		</LinearLayout>
	</FrameLayout>

</LinearLayout>
