<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
	<item android:state_pressed="true">
		<shape android:shape="rectangle">
			<corners android:radius="14dp" />
			<solid android:color="@color/strategyRowPressedFill" />
			<stroke
				android:width="2dp"
				android:color="@color/accent_gold" />
		</shape>
	</item>
	<item android:state_focused="true">
		<shape android:shape="rectangle">
			<corners android:radius="14dp" />
			<solid android:color="@color/strategyRowFocusFill" />
			<stroke
				android:width="2dp"
				android:color="@color/accent_gold" />
		</shape>
	</item>
	<item>
		<shape android:shape="rectangle">
			<corners android:radius="14dp" />
			<solid android:color="@color/strategyRowFill" />
			<stroke
				android:width="2dp"
				android:color="@color/strategyRowStroke" />
		</shape>
	</item>
</selector>
