<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
	<item android:state_activated="true" android:state_pressed="true">
		<shape android:shape="rectangle">
			<corners android:radius="14dp" />
			<solid android:color="@color/detailFavoritePressedFill" />
			<stroke
				android:width="2dp"
				android:color="@color/accent_gold" />
		</shape>
	</item>
	<item android:state_activated="true" android:state_focused="true">
		<shape android:shape="rectangle">
			<corners android:radius="14dp" />
			<solid android:color="@color/detailFavoriteFocusFill" />
			<stroke
				android:width="2dp"
				android:color="@color/accent_gold" />
		</shape>
	</item>
	<item android:state_activated="true">
		<shape android:shape="rectangle">
			<corners android:radius="14dp" />
			<solid android:color="@color/detailFavoriteSelectedFill" />
			<stroke
				android:width="2dp"
				android:color="@color/accent_gold" />
		</shape>
	</item>
	<item android:state_pressed="true">
		<shape android:shape="rectangle">
			<corners android:radius="14dp" />
			<solid android:color="@color/detailActionPressedFill" />
			<stroke
				android:width="2dp"
				android:color="@color/accent_gold" />
		</shape>
	</item>
	<item android:state_focused="true">
		<shape android:shape="rectangle">
			<corners android:radius="14dp" />
			<solid android:color="@color/detailActionFocusFill" />
			<stroke
				android:width="2dp"
				android:color="@color/accent_gold" />
		</shape>
	</item>
	<item>
		<shape android:shape="rectangle">
			<corners android:radius="14dp" />
			<solid android:color="@color/detailActionBaseFill" />
			<stroke
				android:width="2dp"
				android:color="@color/detailActionStroke" />
		</shape>
	</item>
</selector>
