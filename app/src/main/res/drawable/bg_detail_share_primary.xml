<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
	<item android:state_pressed="true">
		<layer-list>
			<item>
				<shape android:shape="rectangle">
					<corners android:radius="14dp" />
					<solid android:color="@color/detailSharePressedFill" />
					<stroke
						android:width="2dp"
						android:color="@color/detailShareOuterStroke" />
				</shape>
			</item>
			<item
				android:left="6dp"
				android:top="6dp"
				android:right="6dp"
				android:bottom="6dp">
				<shape android:shape="rectangle">
					<corners android:radius="10dp" />
					<stroke
						android:width="1dp"
						android:color="@color/accent_gold" />
				</shape>
			</item>
		</layer-list>
	</item>
	<item android:state_focused="true">
		<layer-list>
			<item>
				<shape android:shape="rectangle">
					<corners android:radius="14dp" />
					<solid android:color="@color/detailShareFocusFill" />
					<stroke
						android:width="2dp"
						android:color="@color/detailShareOuterStroke" />
				</shape>
			</item>
			<item
				android:left="6dp"
				android:top="6dp"
				android:right="6dp"
				android:bottom="6dp">
				<shape android:shape="rectangle">
					<corners android:radius="10dp" />
					<stroke
						android:width="1dp"
						android:color="@color/accent_gold" />
				</shape>
			</item>
		</layer-list>
	</item>
	<item>
		<layer-list>
			<item>
				<shape android:shape="rectangle">
					<corners android:radius="14dp" />
					<solid android:color="@color/detailShareFill" />
					<stroke
						android:width="2dp"
						android:color="@color/detailShareOuterStroke" />
				</shape>
			</item>
			<item
				android:left="6dp"
				android:top="6dp"
				android:right="6dp"
				android:bottom="6dp">
				<shape android:shape="rectangle">
					<corners android:radius="10dp" />
					<stroke
						android:width="1dp"
						android:color="@color/detailShareInnerStroke" />
				</shape>
			</item>
		</layer-list>
	</item>
</selector>
