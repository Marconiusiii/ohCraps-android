<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
	<item>
		<shape android:shape="rectangle">
			<corners android:radius="16dp" />
			<solid android:color="@color/formFieldFill" />
			<stroke
				android:width="1dp"
				android:color="@color/contentZoneStroke" />
		</shape>
	</item>
	<item
		android:left="6dp"
		android:top="6dp"
		android:right="6dp"
		android:bottom="6dp">
		<shape android:shape="rectangle">
			<corners android:radius="12dp" />
			<stroke
				android:width="1dp"
				android:color="@color/contentZoneInnerStroke" />
		</shape>
	</item>
</layer-list>
