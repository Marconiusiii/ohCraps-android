<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
	<item
		android:width="3dp"
		android:height="22dp"
		android:gravity="start|center_vertical">
		<shape android:shape="rectangle">
			<gradient
				android:angle="90"
				android:startColor="@color/bottomNavChipGreenDark"
				android:centerColor="@color/bottomNavChipGreenLight"
				android:endColor="@color/bottomNavChipGreenDark" />
		</shape>
	</item>
	<item
		android:left="5dp"
		android:width="3dp"
		android:height="22dp"
		android:gravity="start|center_vertical">
		<shape android:shape="rectangle">
			<gradient
				android:angle="90"
				android:startColor="@color/bottomNavChipGreenDark"
				android:centerColor="@color/bottomNavChipGreenLight"
				android:endColor="@color/bottomNavChipGreenDark" />
		</shape>
	</item>
	<item
		android:left="10dp"
		android:width="3dp"
		android:height="22dp"
		android:gravity="start|center_vertical">
		<shape android:shape="rectangle">
			<gradient
				android:angle="90"
				android:startColor="@color/bottomNavChipWhiteDark"
				android:centerColor="@color/bottomNavChipWhiteLight"
				android:endColor="@color/bottomNavChipWhiteDark" />
		</shape>
	</item>
</layer-list>
