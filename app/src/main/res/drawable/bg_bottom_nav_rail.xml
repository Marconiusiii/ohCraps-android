<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
	<item>
		<shape>
			<gradient
				android:angle="90"
				android:startColor="@color/chipRailHighlight"
				android:centerColor="@color/chipRailLight"
				android:endColor="@color/chipRailDark" />
			<padding
				android:left="8dp"
				android:top="8dp"
				android:right="8dp"
				android:bottom="8dp" />
		</shape>
	</item>
	<item
		android:left="2dp"
		android:top="2dp"
		android:right="2dp"
		android:bottom="2dp">
		<shape>
			<stroke
				android:width="1dp"
				android:color="@color/chipPocketStroke" />
		</shape>
	</item>
</layer-list>
