<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
	<item android:state_checked="true">
		<inset
			android:insetLeft="4dp"
			android:insetTop="4dp"
			android:insetRight="4dp"
			android:insetBottom="4dp">
			<layer-list>
				<item>
					<shape android:shape="rectangle">
						<corners android:radius="18dp" />
						<gradient
							android:angle="270"
							android:startColor="@color/chipPocketLight"
							android:endColor="@color/chipPocketDark" />
						<stroke
							android:width="2dp"
							android:color="@color/bottomNavSelectedStroke" />
					</shape>
				</item>
				<item
					android:width="8dp"
					android:height="22dp"
					android:start="12dp"
					android:gravity="start|center_vertical"
					android:drawable="@drawable/bg_bottom_nav_chip_stack_left" />
				<item
					android:width="13dp"
					android:height="22dp"
					android:end="12dp"
					android:gravity="end|center_vertical"
					android:drawable="@drawable/bg_bottom_nav_chip_stack_right" />
			</layer-list>
		</inset>
	</item>
	<item>
		<inset
			android:insetLeft="4dp"
			android:insetTop="4dp"
			android:insetRight="4dp"
			android:insetBottom="4dp">
			<shape android:shape="rectangle">
				<corners android:radius="18dp" />
				<gradient
					android:angle="270"
					android:startColor="@color/chipPocketLight"
					android:endColor="@color/chipPocketDark" />
				<stroke
					android:width="1dp"
					android:color="@color/chipPocketStroke" />
			</shape>
		</inset>
	</item>
</selector>
